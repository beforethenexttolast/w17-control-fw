    [ "servoEsc:GND", "esp:GND.1", "black", [] ],

    [ "servoDrs:PWM", "esp:D18", "yellow", [] ],
    [ "servoDrs:V+", "esp:VIN", "red", [] ],
    [ "servoDrs:GND", "esp:GND.1", "black", [] ],

    [ "potBattery:SIG", "esp:D34", "purple", [] ],
    [ "potBattery:VCC", "esp:3V3", "red", [] ],
    [ "potBattery:GND", "esp:GND.2", "black", [] ],

    [ "rHallPullup:1", "esp:3V3", "red", [] ],
    [ "rHallPullup:2", "esp:D35", "green", [] ],
    [ "btnHall:1.l", "esp:D35", "green", [] ],
    [ "btnHall:2.l", "esp:GND.2", "black", [] ]
